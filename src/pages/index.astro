---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <!-- Hero / Intro -->
    <section id="hero" class="border-b border-border pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Hi, I'm Alex
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="ml-2 inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p class="mt-2 text-lg">
        I'm Alex, 27, from Spain. I have a degree in Computer Science{" "}
        <a
          href="https://informatica.ucm.es/"
          target="_blank"
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          >@UCM</a
        >{" "}
        and studying Geography and History{" "}
        <a
          href="https://www.uned.es/"
          target="_blank"
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          >@UNED</a
        >.
      </p>
      <p class="mt-2 text-base text-foreground/80">
        Mainly interested in backend development, AI applications (computer
        vision & deep neural networks), and autonomous drone flight.
      </p>

      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Find me at:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <!-- Resume / Projects tabbed section -->
    <section id="resume-projects" class="border-b border-border pt-10 pb-6">
      <div class="mb-6 flex items-baseline gap-3">
        <h2
          id="tab-resume"
          role="tab"
          aria-selected="true"
          class="cursor-pointer text-2xl font-semibold tracking-wide transition-opacity"
        >
          Resume
        </h2>
        <span class="text-2xl font-semibold text-foreground/30 select-none"
          >|</span
        >
        <h2
          id="tab-projects"
          role="tab"
          aria-selected="false"
          class="cursor-pointer text-2xl font-semibold tracking-wide text-foreground/30 transition-opacity hover:text-foreground/60"
        >
          Projects
        </h2>
      </div>

      <!-- Resume content -->
      <div id="panel-resume">
        <!-- Work Experience -->
        <div class="mb-8">
          <h3
            class="mb-4 text-lg font-semibold tracking-widest text-accent uppercase"
          >
            Work Experience
          </h3>
          <ul class="space-y-6">
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold">GMV</span>
                <span class="text-sm text-foreground/60"
                  >Apr 2022 – Jul 2025</span
                >
              </div>
              <p class="mt-1 text-sm text-foreground/80">
                Full development cycle of EGNOS projects (MSI, EURONOTAM, AUGUR)
                — from requirements definition with the client to deploying and
                sourcing hardware for their CPD.
              </p>
              <p class="mt-1 text-sm text-foreground/60">
                Java · C++ · Python · PostgreSQL · MySQL · Jenkins
              </p>
            </li>
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold">Stratesys</span>
                <span class="text-sm text-foreground/60"
                  >Dec 2021 – Apr 2022</span
                >
              </div>
              <p class="mt-1 text-sm text-foreground/80">
                Backend development in Java (Spring Boot).
              </p>
            </li>
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold">Elix RegTech</span>
                <span class="text-sm text-foreground/60"
                  >Feb 2021 – Jul 2021</span
                >
              </div>
              <p class="mt-1 text-sm text-foreground/80">
                Backend development in PHP (Laravel).
              </p>
            </li>
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold"
                  >Asociación Life Three</span
                >
                <span class="text-sm text-foreground/60"
                  >Oct 2017 – Apr 2019</span
                >
              </div>
              <p class="mt-1 text-sm text-foreground/80">
                High school teacher for game development.
              </p>
            </li>
          </ul>
        </div>

        <!-- Education -->
        <div class="mb-8">
          <h3
            class="mb-4 text-lg font-semibold tracking-widest text-accent uppercase"
          >
            Education
          </h3>
          <ul class="space-y-6">
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold"
                  >Universidad Complutense de Madrid</span
                >
                <span class="text-sm text-foreground/60">2016 – 2022</span>
              </div>
              <p class="mt-1 text-sm text-foreground/80">
                BSc Software Engineering (Computation itinerary, taught in
                English)
              </p>
              <p class="mt-1 text-sm text-foreground/80">
                Thesis:{" "}
                <a
                  href="https://eprints.ucm.es/id/eprint/74410/"
                  target="_blank"
                  class="underline decoration-dashed underline-offset-4 hover:text-accent"
                >
                  Simulation of Autonomous Flight of UAVs for Search and Rescue
                  Missions
                </a>
              </p>
              <p class="mt-1 text-sm text-foreground/60">
                Awarded the 2022 Cátedra Bosch-UCM in AI applied to IoT
              </p>
            </li>
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold">UNED</span>
                <span class="text-sm text-foreground/60">In progress</span>
              </div>
              <p class="mt-1 text-sm text-foreground/80">
                Degree in Geography and History
              </p>
            </li>
            <li>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-2"
              >
                <span class="text-base font-semibold"
                  >Instituto San Isidro de Madrid</span
                >
                <span class="text-sm text-foreground/60">2010 – 2016</span>
              </div>
              <p class="mt-1 text-sm text-foreground/80">ESO y Bachillerato</p>
              <p class="mt-1 text-sm text-foreground/60">
                Member of the school board for 6 academic years
              </p>
            </li>
          </ul>
        </div>

        <!-- Tech Skills -->
        <div class="mb-8">
          <h3
            class="mb-4 text-lg font-semibold tracking-widest text-accent uppercase"
          >
            Tech Skills
          </h3>
          <dl class="space-y-2 text-sm">
            <div class="flex flex-wrap gap-x-2">
              <dt class="shrink-0 font-semibold">Experienced:</dt>
              <dd class="text-foreground/80">
                Java · Python (Flask, Django) · Docker
              </dd>
            </div>
            <div class="flex flex-wrap gap-x-2">
              <dt class="shrink-0 font-semibold">Familiar:</dt>
              <dd class="text-foreground/80">
                Docker · Apache Kafka · C++ · SQL · Pulumi · Redis · Caddy ·
                Haskell · Go · Solidity · Jenkins
              </dd>
            </div>
            <div class="flex flex-wrap gap-x-2">
              <dt class="shrink-0 font-semibold">Learning:</dt>
              <dd class="text-foreground/80">Kubernetes · APL (BQN) · Rust</dd>
            </div>
            <div class="flex flex-wrap gap-x-2">
              <dt class="shrink-0 font-semibold">Interests:</dt>
              <dd class="text-foreground/80">
                Drones · Back-end · Big Data · DevOps · Esolangs
              </dd>
            </div>
          </dl>
        </div>

        <!-- Languages -->
        <div class="mb-8">
          <h3
            class="mb-4 text-lg font-semibold tracking-widest text-accent uppercase"
          >
            Languages
          </h3>
          <dl class="flex flex-wrap gap-x-6 gap-y-1 text-sm">
            <div class="flex gap-x-2">
              <dt class="font-semibold">Spanish:</dt>
              <dd class="text-foreground/80">Native</dd>
            </div>
            <div class="flex gap-x-2">
              <dt class="font-semibold">English:</dt>
              <dd class="text-foreground/80">Full professional</dd>
            </div>
            <div class="flex gap-x-2">
              <dt class="font-semibold">German:</dt>
              <dd class="text-foreground/80">Limited working</dd>
            </div>
          </dl>
        </div>

        <!-- Relevant Experiences -->
        <div>
          <h3
            class="mb-4 text-lg font-semibold tracking-widest text-accent uppercase"
          >
            Other
          </h3>
          <ul class="space-y-1 text-sm text-foreground/80">
            <li>
              Afiliado a JIU (Jóvenes Izquierda Unida) <span
                class="text-foreground/50">· 2025</span
              >
            </li>
            <li>
              Cooperativista en{" "}
              <a
                href="https://laosa.coop/"
                target="_blank"
                class="underline decoration-dashed underline-offset-4 hover:text-accent"
                >La Osa</a
              >{" "}
              <span class="text-foreground/50">· 2025</span>
            </li>
            <li>
              Voluntario de Greenpeace <span class="text-foreground/50"
                >· 2016</span
              >
            </li>
          </ul>
        </div>
      </div>

      <!-- Projects content -->
      <div id="panel-projects" class="hidden">
        <ul class="space-y-6">
          <li>
            <a
              href="https://3-vaults.com"
              target="_blank"
              class="text-base font-semibold underline decoration-dashed underline-offset-4 hover:text-accent"
              >3-vaults.com</a
            >
            <p class="mt-1 text-sm text-foreground/80">
              File storage with three vault types: open (always accessible),
              timer (unlocks after a set time), and agreement (requires all
              participants to consent before unlocking).
            </p>
          </li>

          <li>
            <div class="flex flex-wrap items-baseline justify-between gap-x-2">
              <span class="text-base font-semibold">Game Server Hosting</span>
              <span class="text-sm text-foreground/60">In progress</span>
            </div>
            <p class="mt-1 text-sm text-foreground/80">
              Scalable infrastructure platform to provision and manage game
              servers on demand — from a single server to a full fleet for
              network operators running and deploying the servers they need.
            </p>
          </li>
        </ul>
      </div>
    </section>

    <!-- Blog Posts -->
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    const tabResume = document.getElementById("tab-resume");
    const tabProjects = document.getElementById("tab-projects");
    const panelResume = document.getElementById("panel-resume");
    const panelProjects = document.getElementById("panel-projects");

    if (!tabResume || !tabProjects || !panelResume || !panelProjects) return;

    function activateResume() {
      panelResume!.classList.remove("hidden");
      panelProjects!.classList.add("hidden");
      tabResume!.classList.remove("text-foreground/30");
      tabResume!.classList.add("text-foreground");
      tabProjects!.classList.add("text-foreground/30");
      tabProjects!.classList.remove(
        "text-foreground",
        "hover:text-foreground/60"
      );
      tabProjects!.classList.add("hover:text-foreground/60");
      tabResume!.setAttribute("aria-selected", "true");
      tabProjects!.setAttribute("aria-selected", "false");
    }

    function activateProjects() {
      panelProjects!.classList.remove("hidden");
      panelResume!.classList.add("hidden");
      tabProjects!.classList.remove(
        "text-foreground/30",
        "hover:text-foreground/60"
      );
      tabProjects!.classList.add("text-foreground");
      tabResume!.classList.add("text-foreground/30");
      tabResume!.classList.remove("text-foreground");
      tabResume!.classList.add("hover:text-foreground/60");
      tabProjects!.setAttribute("aria-selected", "true");
      tabResume!.setAttribute("aria-selected", "false");
    }

    tabResume.addEventListener("click", activateResume);
    tabProjects.addEventListener("click", activateProjects);
  });
</script>
